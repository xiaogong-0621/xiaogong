/* ─── 热门榜单页 ─── */

.music-container {
  min-height: 100vh;
  background: #F5F7FA;
  position: relative;
  overflow: hidden;
  padding-bottom: 120rpx;
}

/* ─── 导航 ─── */
.nav-header-fixed {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  background: rgba(245, 247, 250, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.nav-icon-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
}
.nav-icon-btn image {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0369A1;
}

.nav-placeholder {
  width: 72rpx;
  height: 72rpx;
}

/* ─── Tab 切换 ─── */
.chart-tabs {
  display: flex;
  margin: 16rpx 40rpx 24rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(255,255,255,0.3);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border: 1rpx solid rgba(255,255,255,0.4);
  position: relative;
  z-index: 1;
}

.chart-tab {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  border-radius: 999rpx;
  transition: all 0.2s;
}

.chart-tab.active {
  background: #0EA5E9;
}

.chart-tab-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #86868b;
}

.chart-tab.active .chart-tab-text {
  color: #fff;
}

/* ─── 榜单列表 ─── */
.loading, .empty {
  padding: 120rpx 40rpx;
  text-align: center;
  color: #86868b;
  font-size: 28rpx;
}

.chart-list {
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

.chart-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(255,255,255,0.35);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255,255,255,0.4);
  border-radius: 28rpx;
  transition: transform 0.15s;
}

.chart-item:active {
  transform: scale(0.98);
}

.chart-item.top-3 {
  background: rgba(255,255,255,0.5);
}

/* 排名 */
.chart-rank {
  width: 56rpx;
  text-align: center;
  font-size: 36rpx;
  font-weight: 800;
  font-family: monospace;
  font-variant-numeric: tabular-nums;
  color: #86868b;
  flex-shrink: 0;
}

.chart-rank.gold { color: #f5a623; }
.chart-rank.silver { color: #86868b; }
.chart-rank.bronze { color: #b87333; }

/* 封面 */
.chart-cover-wrap {
  flex-shrink: 0;
}

.chart-cover {
  width: 104rpx;
  height: 104rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.chart-cover-img {
  width: 100%;
  height: 100%;
  border-radius: 28rpx;
}

.chart-initial {
  font-size: 34rpx;
  font-weight: 700;
  color: #0EA5E9;
}

/* 信息 */
.chart-info {
  flex: 1;
  min-width: 0;
}

.chart-song {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.chart-artist {
  font-size: 24rpx;
  color: #86868b;
  display: block;
  margin-top: 2rpx;
}

.chart-plays {
  font-size: 22rpx;
  color: #86868b;
  font-family: monospace;
  font-variant-numeric: tabular-nums;
  display: block;
  margin-top: 4rpx;
}

/* 操作 */
.chart-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.order-btn {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: #0EA5E9;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(14,165,233,0.3);
  transition: transform 0.15s;
}

.order-btn:active {
  transform: scale(0.95);
}

.order-btn.ordered {
  background: #10b981;
  box-shadow: none;
}

.fav-btn {
  width: 48rpx;
  height: 48rpx;
  position: relative;
  border-radius: 50%;
  transition: transform 0.15s;
}

.heart-outline-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.heart-fill-clip {
  position: absolute;
  inset: 0;
  clip-path: circle(0% at 50% 55%);
}
.heart-fill-clip.filled {
  clip-path: circle(75% at 50% 55%);
}
.heart-fill-clip.filling-anim {
  animation: heartFillIn 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
.heart-fill-clip.unfilling-anim {
  animation: heartUnfill 0.3s ease-out forwards;
}

.heart-fill-img {
  width: 100%;
  height: 100%;
}

.glow-ring {
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(239,68,68,0.3) 0%, transparent 70%);
  opacity: 0;
  pointer-events: none;
}
.glow-ring.popping {
  animation: popGlow 0.45s ease-out forwards;
}

.fav-btn.jelly {
  animation: heartJelly 0.55s 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}
.fav-btn.shrink {
  animation: shrinkPop 0.35s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.fav-btn:active {
  transform: scale(0.85);
}

@keyframes heartFillIn {
  0%   { clip-path: circle(0% at 50% 55%); }
  100% { clip-path: circle(75% at 50% 55%); }
}
@keyframes heartUnfill {
  0%   { clip-path: circle(75% at 50% 55%); }
  100% { clip-path: circle(0% at 50% 55%); }
}
@keyframes heartJelly {
  0%   { transform: scale(1); }
  25%  { transform: scale(1.25, 0.8); }
  50%  { transform: scale(0.88, 1.12); }
  70%  { transform: scale(1.1, 0.92); }
  85%  { transform: scale(0.97, 1.03); }
  100% { transform: scale(1, 1); }
}
@keyframes popGlow {
  0%   { transform: scale(0.5); opacity: 0.8; }
  100% { transform: scale(2.2); opacity: 0; }
}
@keyframes shrinkPop {
  0%   { transform: scale(1); }
  40%  { transform: scale(0.75); }
  100% { transform: scale(1); }
}

/* ─── 弹窗 ─── */
.room-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.room-modal {
  width: 680rpx;
  overflow: hidden;
}

.room-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.3);
}

.room-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.room-modal-close {
  font-size: 32rpx;
  color: #86868b;
  padding: 8rpx;
}

.room-modal-body {
  padding: 32rpx;
}

.room-modal-section {
  margin-bottom: 24rpx;
}

.room-modal-label {
  display: block;
  font-size: 26rpx;
  color: #86868b;
  margin-bottom: 16rpx;
}

.room-modal-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.room-modal-input {
  flex: 1;
  height: 80rpx;
  background: rgba(255,255,255,0.5);
  border: 1rpx solid rgba(255,255,255,0.6);
  border-radius: 56rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  text-align: center;
  letter-spacing: 8rpx;
  box-sizing: border-box;
}

.room-modal-placeholder {
  color: #86868b;
  letter-spacing: 0;
  font-size: 28rpx;
}

.room-modal-join-btn {
  width: 200rpx;
  height: 80rpx;
  background: #0EA5E9;
  color: #fff;
  border: none;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 80rpx;
  padding: 0;
  margin: 0;
}

.room-modal-join-btn[disabled] {
  opacity: 0.5;
}

.room-modal-divider {
  text-align: center;
  padding: 16rpx 0;
  position: relative;
}

.room-modal-divider::before, .room-modal-divider::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 180rpx;
  height: 1rpx;
  background: rgba(255,255,255,0.3);
}

.room-modal-divider::before { left: 60rpx; }
.room-modal-divider::after { right: 60rpx; }

.divider-text {
  font-size: 24rpx;
  color: #86868b;
}

.room-modal-request-btn {
  width: 100%;
  height: 80rpx;
  background: transparent;
  color: #0EA5E9;
  border: 2rpx solid #0EA5E9;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.room-modal-request-btn::after {
  border: none;
}

.room-modal-footer {
  border-top: 1rpx solid rgba(255,255,255,0.3);
}

.room-modal-cancel-btn {
  width: 100%;
  height: 88rpx;
  background: transparent;
  color: #86868b;
  border: none;
  border-radius: 0;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.room-modal-cancel-btn::after {
  border: none;
}

/* ─── Duang 重复点歌反馈 ─── */
.chart-list.spring {
  animation: listSpring 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  transform-origin: center top;
}
@keyframes listSpring {
  0% { transform: scaleY(1); }
  20% { transform: scaleY(0.96); }
  50% { transform: scaleY(1.02); }
  75% { transform: scaleY(0.99); }
  100% { transform: scaleY(1); }
}

.duang-toast {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0);
  background: rgba(0,0,0,0.78);
  color: #fff;
  padding: 20rpx 48rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 700;
  z-index: 999;
  pointer-events: none;
  opacity: 0;
  white-space: nowrap;
}
.duang-toast.show {
  animation: duangPop 1s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}
@keyframes duangPop {
  0% { transform: translate(-50%, -50%) scale(0); opacity: 0; }
  30% { transform: translate(-50%, -50%) scale(1.1); opacity: 1; }
  50% { transform: translate(-50%, -50%) scale(0.95); opacity: 1; }
  70% { transform: translate(-50%, -50%) scale(1.02); opacity: 1; }
  100% { transform: translate(-50%, -50%) scale(1); opacity: 0; }
}
