/* ─── 注册页 ─── */

.register-container {
  min-height: 100vh;
  background: #F5F7FA;
  position: relative;
  overflow: hidden;
}

.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 40rpx;
  position: relative;
  z-index: 1;
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-back image {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0369A1;
}

.register-card {
  margin: 32rpx 40rpx;
  padding: 48rpx 40rpx;
  position: relative;
  z-index: 1;
}

.type-tabs {
  display: flex;
  background: rgba(255,255,255,0.4);
  border-radius: 24rpx;
  padding: 8rpx;
  margin-bottom: 40rpx;
}

.type-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #86868b;
  border-radius: 20rpx;
  font-weight: 500;
}

.type-tab.active {
  background: #0EA5E9;
  color: #fff;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.input-item {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.5);
  border: 1rpx solid rgba(255,255,255,0.6);
  border-radius: 56rpx;
  padding: 0 28rpx 0 32rpx;
}

.input-svg-icon {
  flex-shrink: 0;
  margin-right: 16rpx;
  width: 36rpx;
  height: 36rpx;
}

.input-field {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: #1d1d1f;
  background: transparent;
  padding: 0;
}

.placeholder {
  color: #86868b;
}

.register-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #0EA5E9, #38BDF8);
  color: #fff;
  border: none;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 16rpx 48rpx rgba(14,165,233,0.3);
}

