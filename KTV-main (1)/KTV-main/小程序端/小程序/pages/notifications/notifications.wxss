/* ─── 消息通知页 ─── */

.notifications-container {
  min-height: 100vh;
  background: #F5F7FA;
  position: relative;
  overflow: hidden;
}

/* ─── 漂浮光晕 ─── */
.blob {
  position: fixed;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.5;
  pointer-events: none;
}
.blob-1 {
  width: 500rpx;
  height: 500rpx;
  background: rgba(14, 165, 233, 0.15);
  top: -100rpx;
  right: -100rpx;
  animation: float1 15s infinite ease-in-out;
}
.blob-2 {
  width: 400rpx;
  height: 400rpx;
  background: rgba(99, 102, 241, 0.12);
  bottom: 200rpx;
  left: -150rpx;
  animation: float2 12s infinite ease-in-out;
}
.blob-3 {
  width: 350rpx;
  height: 350rpx;
  background: rgba(236, 72, 153, 0.1);
  top: 50%;
  right: -100rpx;
  animation: float3 10s infinite ease-in-out;
}
@keyframes float1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(-30rpx, 30rpx) scale(1.05); }
}
@keyframes float2 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(40rpx, -20rpx) scale(1.08); }
}
@keyframes float3 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(-20rpx, -40rpx) scale(0.95); }
}

/* ─── 固定导航栏 ─── */
.nav-header-fixed {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  background: rgba(245, 247, 250, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.nav-icon-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.back-icon {
  font-size: 40rpx;
  color: #1d1d1f;
}

.nav-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0369A1;
}

.unread-badge {
  background: #ef4444;
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  min-width: 32rpx;
  text-align: center;
}

.nav-action-btn {
  padding: 8rpx 16rpx;
}

.action-text {
  font-size: 26rpx;
  color: #0EA5E9;
  font-weight: 500;
}

/* ─── 加载中 ─── */
.loading {
  padding: 120rpx 0;
  text-align: center;
  color: #86868b;
  font-size: 28rpx;
}

/* ─── 通知列表 ─── */
.notification-list {
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.notification-item {
  display: flex;
  gap: 24rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 28rpx;
  transition: all 0.2s;
}

.notification-item.unread {
  background: rgba(255, 255, 255, 0.85);
  border-color: rgba(14, 165, 233, 0.3);
  box-shadow: 0 4rpx 20rpx rgba(14, 165, 233, 0.1);
}

.notification-item:active {
  transform: scale(0.98);
}

/* ─── 图标 ─── */
.notification-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.icon-text {
  font-size: 40rpx;
}

/* ─── 内容 ─── */
.notification-content {
  flex: 1;
  min-width: 0;
}

.notification-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.notification-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.notification-title.unread {
  color: #0369A1;
}

.unread-dot {
  width: 14rpx;
  height: 14rpx;
  background: #0EA5E9;
  border-radius: 50%;
  flex-shrink: 0;
}

.notification-desc {
  font-size: 26rpx;
  color: #86868b;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.notification-footer {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.notification-time {
  font-size: 22rpx;
  color: #a1a1aa;
}

.notification-tag {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.join-btn {
  margin-top: 16rpx;
  padding: 14rpx 32rpx;
  background: #0EA5E9;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.join-btn text {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

.join-btn:active {
  transform: scale(0.95);
}

/* ─── 空状态 ─── */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #86868b;
}
