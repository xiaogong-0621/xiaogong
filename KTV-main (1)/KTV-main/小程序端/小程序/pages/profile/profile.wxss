.profile-container {
  min-height: 100vh;
  background: #F5F7FA;
  position: relative;
  overflow: hidden;
  z-index: 1;
  padding-bottom: 120rpx;
}

.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 40rpx;
  background: transparent;
  position: relative;
  z-index: 1;
}

.nav-back {
  font-size: 40rpx;
  color: #1d1d1f;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0369A1;
}

.nav-search {
  width: 40rpx;
  height: 40rpx;
}

.nav-icon-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-icon-btn image {
  width: 40rpx;
  height: 40rpx;
}

.section-header {
  padding: 32rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  position: relative;
  z-index: 1;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d1d1f;
}

.section-count {
  font-size: 26rpx;
  color: #86868b;
}

.empty {
  padding: 60rpx 32rpx;
  text-align: center;
  color: #86868b;
  font-size: 28rpx;
}

.favorite-list {
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.favorite-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.04);
  transform-origin: center center;
  overflow: hidden;
  transition: transform 0.1s ease, opacity 0.1s ease;
}

.favorite-item.fav-dismiss {
  animation: favDismiss 0.7s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  pointer-events: none;
}

@keyframes favDismiss {
  0% { transform: scale(1); opacity: 1; max-height: 200rpx; margin-bottom: 0; padding-top: 24rpx; padding-bottom: 24rpx; }
  15% { transform: scale(0.97); opacity: 0.85; }
  60% { transform: scale(0.92); opacity: 0; max-height: 200rpx; margin-bottom: 0; padding-top: 24rpx; padding-bottom: 24rpx; }
  100% { transform: scale(0.88); opacity: 0; max-height: 0; margin-bottom: -20rpx; padding-top: 0; padding-bottom: 0; }
}

.fav-cover-wrap {
  width: 96rpx;
  height: 96rpx;
  margin-right: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.favorite-cover {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  pointer-events: none;
}

.fav-cover-fallback {
  width: 96rpx;
  height: 96rpx;
  background: rgba(0, 122, 255, 0.12);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-icon {
  font-size: 40rpx;
  color: #fff;
}

.favorite-info {
  flex: 1;
}

.favorite-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  display: block;
  margin-bottom: 8rpx;
}

.favorite-artist {
  font-size: 24rpx;
  color: #86868b;
}

.favorite-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.delete-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.delete-btn image {
  width: 36rpx;
  height: 36rpx;
}

.delete-icon {
  font-size: 32rpx;
  color: #ec4899;
}

.order-btn {
  background: #0EA5E9;
  color: #fff;
  border: none;
  border-radius: 999rpx;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.order-btn.ordered {
  background: #10b981;
  color: #fff;
}

/* 加入房间弹窗 */
.room-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.room-modal {
  width: 680rpx;
  overflow: hidden;
}

.room-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.3);
}

.room-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.room-modal-close {
  font-size: 36rpx;
  color: #86868b;
  padding: 8rpx;
}

.room-modal-body {
  padding: 32rpx;
}

.room-modal-section {
  margin-bottom: 24rpx;
}

.room-modal-label {
  display: block;
  font-size: 26rpx;
  color: #86868b;
  margin-bottom: 16rpx;
}

.room-modal-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.room-modal-input {
  flex: 1;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.45);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 56rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  text-align: center;
  letter-spacing: 8rpx;
  box-sizing: border-box;
}

.room-modal-placeholder {
  color: #86868b;
  letter-spacing: 0;
  font-size: 28rpx;
}

.room-modal-join-btn {
  width: 200rpx;
  height: 80rpx;
  background: #0EA5E9;
  color: #fff;
  border: none;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 80rpx;
  padding: 0;
  margin: 0;
}

.room-modal-join-btn[disabled] {
  opacity: 0.5;
}

.room-modal-divider {
  text-align: center;
  padding: 16rpx 0;
  position: relative;
}

.room-modal-divider::before,
.room-modal-divider::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 180rpx;
  height: 1rpx;
  background: rgba(255,255,255,0.3);
}

.room-modal-divider::before {
  left: 60rpx;
}

.room-modal-divider::after {
  right: 60rpx;
}

.divider-text {
  font-size: 24rpx;
  color: #86868b;
}

.room-modal-request-btn {
  width: 100%;
  height: 80rpx;
  background: transparent;
  color: #0EA5E9;
  border: 2rpx solid #0EA5E9;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.room-modal-request-btn::after {
  border: none;
}

.room-modal-footer {
  border-top: 1rpx solid rgba(255,255,255,0.3);
}

.room-modal-cancel-btn {
  width: 100%;
  height: 88rpx;
  background: transparent;
  color: #86868b;
  border: none;
  border-radius: 0;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.room-modal-cancel-btn::after {
  border: none;
}

/* ─── Duang 重复点歌反馈 ─── */
.favorite-list.spring {
  animation: listSpring 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  transform-origin: center top;
}
@keyframes listSpring {
  0% { transform: scaleY(1); }
  20% { transform: scaleY(0.96); }
  50% { transform: scaleY(1.02); }
  75% { transform: scaleY(0.99); }
  100% { transform: scaleY(1); }
}

.duang-toast {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(0);
  background: rgba(0,0,0,0.78);
  color: #fff;
  padding: 20rpx 48rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
  font-weight: 700;
  z-index: 999;
  pointer-events: none;
  opacity: 0;
  white-space: nowrap;
}
.duang-toast.show {
  animation: duangPop 1s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}
@keyframes duangPop {
  0% { transform: translate(-50%, -50%) scale(0); opacity: 0; }
  30% { transform: translate(-50%, -50%) scale(1.1); opacity: 1; }
  50% { transform: translate(-50%, -50%) scale(0.95); opacity: 1; }
  70% { transform: translate(-50%, -50%) scale(1.02); opacity: 1; }
  100% { transform: translate(-50%, -50%) scale(1); opacity: 0; }
}
