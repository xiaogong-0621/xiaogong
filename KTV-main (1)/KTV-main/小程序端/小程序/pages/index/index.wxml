<view class="login-container" style="padding-top: {{statusBarHeight}}rpx">
  <!-- animated gradient background with floating blobs -->
  <view class="bg-gradient"></view>
  <view class="blob blob-1"></view>
  <view class="blob blob-2"></view>
  <view class="blob blob-3"></view>
  <view class="blob blob-4"></view>
  <view class="blob blob-5"></view>

  <view class="login-card glass">
    <!-- mic SVG icon -->
    <view class="logo-wrap">
      <view class="logo-icon">
        <image src="data:image/svg+xml;base64," mode="aspectFit"/>
      </view>
    </view>
    <text class="app-name">SONIC CANVAS</text>
    <text class="app-subtitle">声域友 — 线上社交 KTV</text>

    <view class="input-group">
      <view class="input-item">
        <view class="input-icon-wrap">
          <image src="data:image/svg+xml;base64," mode="aspectFit"/>
        </view>
        <input
          class="input-field"
          placeholder="用户名 / 手机号 / 邮箱"
          placeholder-class="placeholder"
          bindinput="onUsernameInput"
          value="{{username}}"
        />
      </view>
      <view class="input-item">
        <view class="input-icon-wrap">
          <image src="data:image/svg+xml;base64," mode="aspectFit"/>
        </view>
        <input
          class="input-field"
          type="password"
          placeholder="密码"
          placeholder-class="placeholder"
          bindinput="onPasswordInput"
          value="{{password}}"
        />
      </view>
    </view>

    <button class="login-btn" bindtap="login">登 录</button>
    <view class="register-link" bindtap="goToRegister">
      <text class="register-text">还没有账号？</text>
      <text class="register-action">立即注册</text>
    </view>
  </view>
</view>
