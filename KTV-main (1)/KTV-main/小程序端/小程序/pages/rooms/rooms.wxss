/* ─── 房间列表页 ─── */

.rooms-container {
  min-height: 100vh;
  background: #F5F7FA;
  position: relative;
  overflow: hidden;
  padding-bottom: 40rpx;
}

/* ─── 漂浮光晕 ─── */
.blob {
  position: fixed;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.5;
  pointer-events: none;
}
.blob-1 {
  width: 500rpx;
  height: 500rpx;
  background: rgba(14, 165, 233, 0.15);
  top: -100rpx;
  right: -100rpx;
  animation: float1 15s infinite ease-in-out;
}
.blob-2 {
  width: 400rpx;
  height: 400rpx;
  background: rgba(99, 102, 241, 0.12);
  bottom: 200rpx;
  left: -150rpx;
  animation: float2 12s infinite ease-in-out;
}
.blob-3 {
  width: 350rpx;
  height: 350rpx;
  background: rgba(236, 72, 153, 0.1);
  top: 50%;
  right: -100rpx;
  animation: float3 10s infinite ease-in-out;
}
@keyframes float1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(-30rpx, 30rpx) scale(1.05); }
}
@keyframes float2 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(40rpx, -20rpx) scale(1.08); }
}
@keyframes float3 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(-20rpx, -40rpx) scale(0.95); }
}

/* ─── 固定导航栏 ─── */
.nav-header-fixed {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  background: rgba(245, 247, 250, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.nav-icon-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 40rpx;
  color: #1d1d1f;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0369A1;
}

.nav-placeholder {
  width: 72rpx;
  height: 72rpx;
}

/* ─── 统计栏 ─── */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 40rpx;
  position: relative;
  z-index: 1;
}

.stats-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stats-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.stats-count {
  font-size: 30rpx;
  font-weight: 700;
  color: #0EA5E9;
}

.create-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  background: #0EA5E9;
  border-radius: 999rpx;
}

.create-btn:active {
  transform: scale(0.95);
}

.create-icon {
  font-size: 28rpx;
  color: #fff;
  font-weight: 700;
}

.create-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

/* ─── 搜索区域 ─── */
.search-section {
  padding: 0 40rpx 16rpx;
  position: relative;
  z-index: 1;
}

.search-bar {
  display: flex;
  align-items: center;
  padding: 0 24rpx 0 28rpx;
  border-radius: 56rpx;
  height: 72rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: #1d1d1f;
}

.placeholder {
  color: #86868b;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0,0,0,0.08);
  flex-shrink: 0;
}

.search-clear text {
  font-size: 22rpx;
  color: #86868b;
  line-height: 1;
}

/* ─── 输入房间码区域 ─── */
.join-code-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 0 40rpx 24rpx;
  position: relative;
  z-index: 1;
}

.join-code-input {
  flex: 1;
  height: 72rpx;
  background: rgba(255,255,255,0.45);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  border-radius: 56rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  text-align: center;
  letter-spacing: 4rpx;
}

.join-code-btn {
  padding: 14rpx 36rpx;
  background: #0EA5E9;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.join-code-btn:active {
  transform: scale(0.95);
}

.join-code-btn text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

/* ─── 房间列表 ─── */
.rooms-section {
  padding: 0 40rpx;
  position: relative;
  z-index: 1;
}

.loading {
  padding: 120rpx 0;
  text-align: center;
  color: #86868b;
  font-size: 28rpx;
}

.rooms-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0 80rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(14,165,233,0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.empty-emoji {
  font-size: 56rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d1d1f;
  margin-bottom: 8rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #86868b;
}

.rooms-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* ─── 房间卡片 ─── */
.room-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
}

.room-card-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.room-card-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, rgba(14,165,233,0.15), rgba(99,102,241,0.15));
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.room-card-emoji {
  font-size: 40rpx;
}

.room-card-info {
  flex: 1;
  min-width: 0;
}

.room-card-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  display: block;
  margin-bottom: 4rpx;
}

.room-card-code {
  font-size: 24rpx;
  color: #86868b;
  font-family: 'SF Mono', 'Menlo', 'Consolas', monospace;
  display: block;
  margin-bottom: 4rpx;
}

.room-card-users {
  font-size: 22rpx;
  color: #10b981;
  font-weight: 500;
}

.room-card-join {
  padding: 14rpx 32rpx;
  background: #0EA5E9;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.room-card-join:active {
  transform: scale(0.95);
}

.room-card-join text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

/* ─── 毛玻璃效果 ─── */
.glass-sm {
  background: rgba(255,255,255,0.45);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
}
