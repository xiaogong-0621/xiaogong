.room-select-container {
  min-height: 100vh;
  background: #F5F7FA;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.room-select-card {
  padding: 60rpx 40rpx;
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

.logo-wrap {
  margin-bottom: 32rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  background: #e8edf2;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #0369A1;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #86868b;
  margin-bottom: 48rpx;
}

.action-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.action-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.35);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 24rpx;
}

.action-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.action-info {
  flex: 1;
}

.action-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1d1d1f;
  display: block;
  margin-bottom: 4rpx;
}

.action-desc {
  font-size: 24rpx;
  color: #86868b;
}

.code-input-wrap {
  padding: 32rpx;
  background: rgba(255, 255, 255, 0.35);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 24rpx;
}

.code-input {
  width: 100%;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 56rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  text-align: center;
  letter-spacing: 12rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  color: #1d1d1f;
}

.placeholder {
  color: #86868b;
  letter-spacing: 0;
}

.join-btn {
  width: 100%;
  height: 80rpx;
  background: #0EA5E9;
  color: #fff;
  border: none;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 122, 255, 0.3);
  font-size: 30rpx;
  font-weight: 600;
}

.skip-link {
  padding: 24rpx 48rpx;
}
.skip-link text {
  font-size: 26rpx;
  color: #0EA5E9;
}
