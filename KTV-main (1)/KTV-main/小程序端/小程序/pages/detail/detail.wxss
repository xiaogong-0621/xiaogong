.detail-container {
  min-height: 100vh;
  background: #F5F7FA;
  position: relative;
  overflow: hidden;
  z-index: 1;
}

.nav-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 40rpx;
  background: transparent;
  z-index: 100;
}

.nav-back {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-back image {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0369A1;
}

.nav-action {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.nav-action image {
  width: 40rpx;
  height: 40rpx;
}

.song-card {
  padding: 100rpx 32rpx 32rpx;
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
  overflow: hidden;
}

.song-card-bg {
  position: absolute;
  top: -40rpx;
  left: -40rpx;
  right: -40rpx;
  bottom: -40rpx;
  z-index: -1;
  overflow: hidden;
}

.song-card-bg-img {
  width: 100%;
  height: 100%;
  filter: blur(60rpx) brightness(0.6) saturate(1.4);
  transform: scale(1.2);
}

.cover-wrap {
  width: 360rpx;
  height: 360rpx;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.04);
}

.song-cover {
  width: 360rpx;
  height: 360rpx;
  border-radius: 24rpx;
}

.cover-fallback {
  width: 360rpx;
  height: 360rpx;
  background: rgba(0, 122, 255, 0.12);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cover-icon {
  font-size: 80rpx;
  color: #fff;
}

.song-info {
  text-align: center;
}

.song-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #1d1d1f;
  display: block;
  margin-bottom: 12rpx;
}

.song-artist {
  font-size: 28rpx;
  color: #86868b;
  display: block;
  margin-bottom: 8rpx;
}

.song-album {
  font-size: 24rpx;
  color: #86868b;
}

.song-actions {
  margin-top: 28rpx;
}

.detail-actions {
  padding: 24rpx 40rpx;
  display: flex;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.detail-actions .order-btn {
  background: #0EA5E9;
  color: #fff;
  border: none;
  border-radius: 999rpx;
  padding: 16rpx 64rpx;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.6;
  margin: 0;
}

.detail-actions .order-btn.ordered {
  background: #10b981;
  color: #fff;
  border-color: #10b981;
}

.lyrics-section {
  padding: 32rpx 40rpx;
  position: relative;
  z-index: 1;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
  margin-bottom: 24rpx;
  display: block;
}

.lyrics-scroll {
  height: 600rpx;
}

.lyrics-container {
  padding: 20rpx 0;
}

.lyric-item {
  padding: 16rpx 0;
  text-align: center;
  transition: all 0.3s ease;
}

.lyric-text {
  font-size: 28rpx;
  color: #86868b;
  line-height: 1.8;
}

.lyric-item.active .lyric-text {
  font-size: 34rpx;
  color: #0EA5E9;
  font-weight: 500;
}

.progress-section {
  padding: 24rpx 40rpx;
  padding-bottom: 200rpx;
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  position: relative;
  z-index: 1;
}

.time-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.current-time, .total-time {
  font-size: 24rpx;
  color: #86868b;
}

.progress-bar {
  position: relative;
}

.progress-track {
  position: relative;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
}

.progress-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  background: #0EA5E9;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-thumb {
  position: absolute;
  top: 50%;
  width: 20rpx;
  height: 20rpx;
  background: #0EA5E9;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: left 0.3s ease;
}

.player-controls {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 80rpx;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.5);
}

.control-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.control-btn image {
  width: 48rpx;
  height: 48rpx;
}

.control-icon {
  width: 48rpx;
  height: 48rpx;
}

.play-btn {
  width: 112rpx;
  height: 112rpx;
  background: #0EA5E9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.play-btn image {
  width: 48rpx;
  height: 48rpx;
}

.play-icon {
  font-size: 48rpx;
  color: #fff;
}

/* 加入房间弹窗 */
.room-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.room-modal {
  width: 680rpx;
  overflow: hidden;
}

.room-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.3);
}

.room-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1d1d1f;
}

.room-modal-close {
  font-size: 36rpx;
  color: #86868b;
  padding: 8rpx;
}

.room-modal-body { padding: 32rpx; }
.room-modal-section { margin-bottom: 24rpx; }

.room-modal-label {
  display: block;
  font-size: 26rpx;
  color: #86868b;
  margin-bottom: 16rpx;
}

.room-modal-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.room-modal-input {
  flex: 1;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.45);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 56rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  text-align: center;
  letter-spacing: 8rpx;
  box-sizing: border-box;
}

.room-modal-placeholder {
  color: #86868b;
  letter-spacing: 0;
  font-size: 28rpx;
}

.room-modal-join-btn {
  width: 200rpx;
  height: 80rpx;
  background: #0EA5E9;
  color: #fff;
  border: none;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 80rpx;
  padding: 0;
  margin: 0;
}

.room-modal-join-btn[disabled] { opacity: 0.5; }

.room-modal-divider {
  text-align: center;
  padding: 16rpx 0;
  position: relative;
}

.room-modal-divider::before,
.room-modal-divider::after {
  content: '';
  position: absolute;
  top: 50%;
  width: 180rpx;
  height: 1rpx;
  background: rgba(255,255,255,0.3);
}

.room-modal-divider::before { left: 60rpx; }
.room-modal-divider::after { right: 60rpx; }

.divider-text {
  font-size: 24rpx;
  color: #86868b;
}

.room-modal-request-btn {
  width: 100%;
  height: 80rpx;
  background: transparent;
  color: #0EA5E9;
  border: 2rpx solid #0EA5E9;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.room-modal-request-btn::after { border: none; }

.room-modal-footer { border-top: 1rpx solid rgba(255,255,255,0.3); }

.room-modal-cancel-btn {
  width: 100%;
  height: 88rpx;
  background: transparent;
  color: #86868b;
  border: none;
  border-radius: 0;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  margin: 0;
}

.room-modal-cancel-btn::after { border: none; }
