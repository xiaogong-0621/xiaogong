/* ═══════════════════════════════════════════
   声域友 SONIC CANVAS — 设计系统
   ═══════════════════════════════════════════ */

page {
  background: #F5F7FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', system-ui, sans-serif;
  font-size: 30rpx;
  line-height: 1.5;
  color: #1d1d1f;
}

/* ─── 导航栏毛玻璃 ─── */
.nav-header {
  background: rgba(245,247,250,0.75);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border-bottom: 1rpx solid rgba(255,255,255,0.5);
}

/* ─── 背景光晕（5 色漂浮动画） ─── */
.blob {
  position: fixed;
  z-index: 0;
  pointer-events: none;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.45;
  will-change: transform;
}

.blob-1 {
  width: 900rpx; height: 900rpx;
  top: -400rpx; left: -300rpx;
  background: radial-gradient(circle, #71fcfe, transparent 70%);
  animation: blob-float-1 5s ease-in-out infinite;
}
.blob-2 {
  width: 800rpx; height: 800rpx;
  top: -100rpx; right: -400rpx;
  background: radial-gradient(circle, #71fcfe, transparent 70%);
  animation: blob-float-2 6s ease-in-out infinite;
}
.blob-3 {
  width: 700rpx; height: 700rpx;
  top: 500rpx; left: 100rpx;
  background: radial-gradient(circle, #71fcfe, transparent 70%);
  animation: blob-float-3 7s ease-in-out infinite;
}
.blob-4 {
  width: 750rpx; height: 750rpx;
  bottom: -200rpx; right: -200rpx;
  background: radial-gradient(circle, #71fcfe, transparent 70%);
  animation: blob-float-4 4s ease-in-out infinite;
}
.blob-5 {
  width: 650rpx; height: 650rpx;
  top: 1200rpx; left: -150rpx;
  background: radial-gradient(circle, #71fcfe, transparent 70%);
  animation: blob-float-5 8s ease-in-out infinite;
}

@keyframes blob-float-1 {
  0%,100%{transform:translate(0,0)} 33%{transform:translate(150rpx,200rpx)} 66%{transform:translate(-100rpx,250rpx)}
}
@keyframes blob-float-2 {
  0%,100%{transform:translate(0,0)} 33%{transform:translate(-180rpx,140rpx)} 66%{transform:translate(120rpx,-100rpx)}
}
@keyframes blob-float-3 {
  0%,100%{transform:translate(0,0)} 33%{transform:translate(220rpx,-140rpx)} 66%{transform:translate(-160rpx,100rpx)}
}
@keyframes blob-float-4 {
  0%,100%{transform:translate(0,0)} 33%{transform:translate(-120rpx,-180rpx)} 66%{transform:translate(180rpx,60rpx)}
}
@keyframes blob-float-5 {
  0%,100%{transform:translate(0,0)} 33%{transform:translate(160rpx,100rpx)} 66%{transform:translate(-180rpx,-140rpx)}
}

/* ─── 通用毛玻璃卡片 ─── */
.glass {
  background: rgba(255,255,255,0.75);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border: 1rpx solid rgba(255,255,255,0.5);
  border-radius: 48rpx;
  box-shadow: 0 40rpx 120rpx rgba(14,165,233,0.12);
}

.glass-sm {
  background: rgba(255,255,255,0.65);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  border: 1rpx solid rgba(255,255,255,0.4);
  border-radius: 28rpx;
}

/* ─── 通用按钮 ─── */
.btn-primary {
  background: linear-gradient(135deg, #0EA5E9, #38BDF8);
  color: #fff;
  border: none;
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 48rpx;
  box-shadow: 0 16rpx 48rpx rgba(14,165,233,0.3);
}

.btn-primary:active {
  transform: scale(0.98);
}

.btn-secondary {
  background: rgba(255,255,255,0.35);
  backdrop-filter: blur(20rpx);
  color: #86868b;
  border: 1rpx solid rgba(255,255,255,0.5);
  border-radius: 999rpx;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
}

/* ─── 文字颜色 ─── */
.text-primary { color: #0EA5E9; }
.text-secondary { color: #86868b; }
.text-muted { color: #86868b; }
.text-fg { color: #1d1d1f; }

/* ─── 布局 ─── */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.flex-1 { flex: 1; }

/* ─── 间距 ─── */
.mt-4 { margin-top: 16rpx; }
.mt-8 { margin-top: 32rpx; }
.mt-12 { margin-top: 48rpx; }
.mb-4 { margin-bottom: 16rpx; }
.mb-8 { margin-bottom: 32rpx; }
.p-4 { padding: 16rpx; }
.p-8 { padding: 32rpx; }
